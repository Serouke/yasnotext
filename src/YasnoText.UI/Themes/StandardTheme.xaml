<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- Цвета -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="#F5F5F0" />
    <SolidColorBrush x:Key="ReadingBackgroundBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="TextBrush" Color="#2C2C2A" />
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="#666666" />
    <SolidColorBrush x:Key="AccentBrush" Color="#1E88E5" />
    <SolidColorBrush x:Key="BorderBrush" Color="#D0D0C8" />
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FFFFFF" />

    <!-- Шрифты -->
    <FontFamily x:Key="UIFontFamily">Segoe UI</FontFamily>
    <FontFamily x:Key="ReadingFontFamily">Segoe UI</FontFamily>

    <!-- Размеры -->
    <sys:Double x:Key="ReadingFontSize">14</sys:Double>
    <sys:Double x:Key="ReadingLineHeight">21</sys:Double>
    <FontWeight x:Key="ReadingFontWeight">Normal</FontWeight>

</ResourceDictionary>
