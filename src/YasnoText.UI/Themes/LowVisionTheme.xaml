<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- Цвета: жёлтый текст на чёрном фоне (контраст 21:1, WCAG AAA) -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#000000" />
    <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="#000000" />
    <SolidColorBrush x:Key="ReadingBackgroundBrush" Color="#000000" />
    <SolidColorBrush x:Key="TextBrush" Color="#FFFF00" />
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="#FFFF00" />
    <SolidColorBrush x:Key="AccentBrush" Color="#FFFF00" />
    <SolidColorBrush x:Key="BorderBrush" Color="#FFFF00" />
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#000000" />

    <!-- Шрифты -->
    <FontFamily x:Key="UIFontFamily">Arial</FontFamily>
    <FontFamily x:Key="ReadingFontFamily">Arial</FontFamily>

    <!-- Размеры: крупный жирный шрифт -->
    <sys:Double x:Key="ReadingFontSize">28</sys:Double>
    <sys:Double x:Key="ReadingLineHeight">48</sys:Double>
    <FontWeight x:Key="ReadingFontWeight">Bold</FontWeight>

</ResourceDictionary>
