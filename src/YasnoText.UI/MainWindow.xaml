<Window x:Class="YasnoText.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:YasnoText.UI.ViewModels"
        mc:Ignorable="d"
        Title="ЯсноТекст"
        Height="720"
        Width="1180"
        MinHeight="500"
        MinWidth="900"
        WindowStartupLocation="CenterScreen"
        AllowDrop="True"
        DragEnter="OnWindowDragEnter"
        DragOver="OnWindowDragOver"
        DragLeave="OnWindowDragLeave"
        Drop="OnWindowDrop"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource TextBrush}"
        FontFamily="{DynamicResource UIFontFamily}">

    <Window.Resources>

        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!-- Кнопка панели инструментов: тонкая рамка, hover заливает AccentBrush
             и сливает рамку с фоном. -->
        <Style x:Key="ToolbarButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,7" />
            <Setter Property="Margin" Value="0,0,4,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"
                                              TextElement.Foreground="{TemplateBinding Foreground}"
                                              TextElement.FontFamily="{TemplateBinding FontFamily}"
                                              TextElement.FontSize="{TemplateBinding FontSize}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentBrush}" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource WindowBackgroundBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Большая кнопка onboarding-экрана. -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource WindowBackgroundBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="22,10" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"
                                              TextElement.Foreground="{TemplateBinding Foreground}"
                                              TextElement.FontFamily="{TemplateBinding FontFamily}"
                                              TextElement.FontSize="{TemplateBinding FontSize}"
                                              TextElement.FontWeight="{TemplateBinding FontWeight}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.85" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="MenuItem">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="Background" Value="{DynamicResource WindowBackgroundBrush}" />
        </Style>

        <Style TargetType="Menu">
            <Setter Property="Background" Value="{DynamicResource WindowBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
        </Style>

        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>

        <Style x:Key="ProfileCardBorder" TargetType="Border">
            <Setter Property="BorderThickness" Value="1.5" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Style.Triggers>
                <!-- Hover на неактивной карточке — рамка подсвечивается
                     акцентным цветом, чтобы дать визуальную обратную связь. -->
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                </Trigger>
                <DataTrigger Binding="{Binding IsActive}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ProfileCardTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsActive}" Value="True">
                    <Setter Property="FontWeight" Value="Bold" />
                    <Setter Property="Foreground" Value="{DynamicResource WindowBackgroundBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ProfileCardHotkey" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Margin" Value="0,3,0,0" />
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsActive}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource WindowBackgroundBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SettingLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,0,0,5" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        </Style>

        <DataTemplate x:Key="ProfileCardTemplate" DataType="{x:Type vm:ProfileItemViewModel}">
            <Border Style="{StaticResource ProfileCardBorder}">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick"
                                  Command="{Binding DataContext.SelectProfileCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                  CommandParameter="{Binding}" />
                </Border.InputBindings>
                <Border.ContextMenu>
                    <!-- ContextMenu в WPF — отдельный visual tree (Popup), поэтому
                         RelativeSource AncestorType=Window отсюда не работает.
                         Команда живёт прямо на ProfileItemViewModel и для встроенных
                         профилей делается серой через CanExecute. -->
                    <ContextMenu>
                        <MenuItem Header="Удалить профиль"
                                  Command="{Binding DeleteCommand}" />
                    </ContextMenu>
                </Border.ContextMenu>
                <StackPanel>
                    <TextBlock Text="{Binding Name}" Style="{StaticResource ProfileCardTitle}" />
                    <TextBlock Text="{Binding HotkeyLabel}" Style="{StaticResource ProfileCardHotkey}" />
                </StackPanel>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid>
    <DockPanel>

        <!-- Главное меню -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="Файл">
                <MenuItem Header="Открыть..."
                          InputGestureText="Ctrl+O"
                          Command="{Binding OpenDocumentCommand}" />
                <MenuItem Header="Недавние"
                          ItemsSource="{Binding RecentFiles}"
                          IsEnabled="{Binding HasRecentFiles}">
                    <MenuItem.ItemContainerStyle>
                        <Style TargetType="MenuItem">
                            <Setter Property="Header" Value="{Binding}" />
                            <Setter Property="Command"
                                    Value="{Binding DataContext.OpenRecentCommand,
                                            RelativeSource={RelativeSource AncestorType=Window}}" />
                            <Setter Property="CommandParameter" Value="{Binding}" />
                        </Style>
                    </MenuItem.ItemContainerStyle>
                </MenuItem>
                <Separator />
                <MenuItem Header="Сохранить как профиль..."
                          InputGestureText="Ctrl+S"
                          Command="{Binding SaveProfileCommand}" />
                <Separator />
                <MenuItem Header="Выход" Command="{Binding ExitCommand}" />
            </MenuItem>
            <MenuItem Header="Профиль">
                <MenuItem Header="Стандартный"
                          InputGestureText="Ctrl+1"
                          Command="{Binding SelectProfileCommand}"
                          CommandParameter="{Binding Profiles[0]}" />
                <MenuItem Header="Слабовидение"
                          InputGestureText="Ctrl+2"
                          Command="{Binding SelectProfileCommand}"
                          CommandParameter="{Binding Profiles[1]}" />
                <MenuItem Header="Дислексия"
                          InputGestureText="Ctrl+3"
                          Command="{Binding SelectProfileCommand}"
                          CommandParameter="{Binding Profiles[2]}" />
            </MenuItem>
            <MenuItem Header="Вид">
                <MenuItem Header="Увеличить шрифт"
                          InputGestureText="Ctrl++"
                          Command="{Binding IncreaseFontCommand}" />
                <MenuItem Header="Уменьшить шрифт"
                          InputGestureText="Ctrl+-"
                          Command="{Binding DecreaseFontCommand}" />
            </MenuItem>
            <MenuItem Header="Справка">
                <MenuItem Header="О программе" Command="{Binding ShowAboutCommand}" />
            </MenuItem>
        </Menu>

        <!-- Панель инструментов: только то, что реально работает. -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource WindowBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="12,10">
            <StackPanel Orientation="Horizontal">
                <Button Content="Открыть"
                        Command="{Binding OpenDocumentCommand}"
                        Style="{StaticResource ToolbarButton}" />
                <Button Content="Сохранить настройки"
                        Command="{Binding SaveProfileCommand}"
                        ToolTip="Сохранить текущие настройки как новый профиль (Ctrl+S)"
                        Style="{StaticResource ToolbarButton}" />

                <Rectangle Width="1" Margin="10,4"
                           Fill="{DynamicResource BorderBrush}" />

                <Button Content="A−"
                        Command="{Binding DecreaseFontCommand}"
                        FontWeight="SemiBold"
                        Style="{StaticResource ToolbarButton}" />
                <TextBlock Text="{Binding CurrentFontSize, StringFormat={}{0:0}pt}"
                           VerticalAlignment="Center"
                           Margin="6,0"
                           MinWidth="36"
                           TextAlignment="Center"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           FontSize="12" />
                <Button Content="A+"
                        Command="{Binding IncreaseFontCommand}"
                        FontWeight="SemiBold"
                        Style="{StaticResource ToolbarButton}" />

                <Rectangle Width="1" Margin="10,4"
                           Fill="{DynamicResource BorderBrush}" />

                <Button x:Name="AutoScrollButton"
                        Content="Автопрокрутка"
                        Click="OnAutoScrollButtonClick"
                        ToolTip="Включить автопрокрутку. Также — щелчок средней кнопкой мыши по документу. Выход — Esc или любой клик."
                        Style="{StaticResource ToolbarButton}" />
            </StackPanel>
        </Border>

        <!-- Строка состояния -->
        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource SidebarBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="12,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{Binding DocumentInfo}"
                           FontSize="12"
                           Foreground="{DynamicResource SecondaryTextBrush}" />
                <TextBlock Grid.Column="1"
                           Text="{Binding StatusText}"
                           FontSize="12"
                           Foreground="{DynamicResource SecondaryTextBrush}" />
            </Grid>
        </Border>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{DynamicResource SidebarBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,1,0">
                <!-- ScrollViewer вокруг всего sidebar — иначе при большом
                     количестве пользовательских профилей список не помещается
                     по высоте и без прокрутки до настроек не добраться. -->
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="16,18">
                    <StackPanel>
                        <TextBlock Text="ПРОФИЛИ" Style="{StaticResource SectionLabel}" />

                        <ItemsControl ItemsSource="{Binding Profiles}"
                                      ItemTemplate="{StaticResource ProfileCardTemplate}" />

                        <Rectangle Height="1" Margin="0,18,0,18"
                                   Fill="{DynamicResource BorderBrush}" />

                        <TextBlock Text="НАСТРОЙКИ" Style="{StaticResource SectionLabel}" />

                        <TextBlock Text="Шрифт" Style="{StaticResource SettingLabel}" />
                        <ComboBox ItemsSource="{Binding AvailableFonts}"
                                  SelectedItem="{Binding CurrentFontFamily}"
                                  Margin="0,0,0,14"
                                  Foreground="Black" />

                        <TextBlock Text="Межстрочный интервал" Style="{StaticResource SettingLabel}" />
                        <Slider Minimum="1" Maximum="3"
                                Value="{Binding CurrentLineHeight, Mode=TwoWay}"
                                TickFrequency="0.5"
                                IsSnapToTickEnabled="False" />
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Область чтения. Два состояния: onboarding (нет документа) и
                 текстовый просмотр (документ открыт). Visibility — через
                 BooleanToVisibilityConverter и инверсный bool в VM. -->
            <Grid Grid.Column="1" Background="{DynamicResource ReadingBackgroundBrush}">

                <!-- Onboarding-экран до первого открытия документа. -->
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            MaxWidth="460"
                            Visibility="{Binding HasNoDocument, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="ЯсноТекст"
                               FontSize="40"
                               FontWeight="SemiBold"
                               TextAlignment="Center"
                               Foreground="{DynamicResource TextBrush}" />
                    <TextBlock Text="Превращает «недоступные» PDF, DOCX и сканы в удобную среду для чтения."
                               FontSize="14"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               LineHeight="22"
                               Margin="0,12,0,28"
                               Foreground="{DynamicResource SecondaryTextBrush}" />
                    <Button Content="Открыть документ"
                            Command="{Binding OpenDocumentCommand}"
                            Style="{StaticResource PrimaryButton}"
                            HorizontalAlignment="Center" />
                    <TextBlock Text="или нажмите Ctrl+O"
                               FontSize="11"
                               TextAlignment="Center"
                               Margin="0,10,0,28"
                               Foreground="{DynamicResource SecondaryTextBrush}" />
                    <TextBlock TextAlignment="Center"
                               LineHeight="22"
                               FontSize="12"
                               Foreground="{DynamicResource SecondaryTextBrush}">
                        <Run Text="Профиль чтения: " />
                        <Run Text="Ctrl+1" FontWeight="SemiBold" />
                        <Run Text=" · " />
                        <Run Text="Ctrl+2" FontWeight="SemiBold" />
                        <Run Text=" · " />
                        <Run Text="Ctrl+3" FontWeight="SemiBold" />
                        <LineBreak />
                        <Run Text="Размер шрифта: " />
                        <Run Text="Ctrl++" FontWeight="SemiBold" />
                        <Run Text=" / " />
                        <Run Text="Ctrl+−" FontWeight="SemiBold" />
                    </TextBlock>
                </StackPanel>

                <!-- Текст документа. FlowDocumentScrollViewer вместо TextBlock —
                     у первого встроенная виртуализация на уровне Paragraph,
                     один TextBlock на 250-страничный PDF просто не скроллится.
                     Бонусом возвращается выделение/копирование текста и
                     встроенный поиск Ctrl+F. FlowDocument строится в
                     code-behind: см. UpdateReadingDocument в MainWindow.xaml.cs. -->
                <FlowDocumentScrollViewer x:Name="ReadingViewer"
                                          IsToolBarVisible="False"
                                          Background="{DynamicResource ReadingBackgroundBrush}"
                                          Foreground="{DynamicResource TextBrush}"
                                          FontFamily="{Binding CurrentFontFamily}"
                                          FontSize="{Binding CurrentFontSize}"
                                          Visibility="{Binding HasDocument, Converter={StaticResource BoolToVis}}" />

                <!-- Overlay для индикатора автопрокрутки. IsHitTestVisible=False,
                     чтобы клики через якорь доходили до viewer'а. Видимость и
                     позиция управляются из code-behind. -->
                <Canvas x:Name="AutoScrollOverlay"
                        IsHitTestVisible="False"
                        Visibility="Collapsed">
                    <Border x:Name="AutoScrollAnchor"
                            Width="36" Height="36"
                            CornerRadius="18"
                            Background="#A0606060"
                            BorderBrush="#FFFFFFFF"
                            BorderThickness="1">
                        <TextBlock Text="↕"
                                   Foreground="White"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>
                </Canvas>
            </Grid>
        </Grid>

    </DockPanel>

        <!-- Overlay при drag-and-drop файла. IsHitTestVisible=False, чтобы
             события Drop/DragLeave доходили до Window — иначе drop попадал бы
             в overlay и не срабатывал. Полупрозрачный чёрный фон одинаково
             хорошо смотрится на всех трёх темах. -->
        <Border x:Name="DropOverlay"
                Visibility="Collapsed"
                IsHitTestVisible="False"
                Background="#B0000000">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                <TextBlock Text="Отпустите, чтобы открыть"
                           FontSize="28"
                           FontWeight="SemiBold"
                           Foreground="White"
                           HorizontalAlignment="Center" />
                <TextBlock Text="PDF · DOCX · изображение"
                           FontSize="13"
                           Foreground="#CCFFFFFF"
                           Margin="0,10,0,0"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
