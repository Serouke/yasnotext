<Window x:Class="YasnoText.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:YasnoText.UI.ViewModels"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}"
        Height="720"
        Width="1180"
        MinHeight="500"
        MinWidth="900"
        WindowStartupLocation="CenterScreen"
        AllowDrop="True"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource TextBrush}"
        FontFamily="{DynamicResource UIFontFamily}">

    <Window.Resources>

        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!-- Тематически-нейтральный ComboBox: фон и текст идут из темы,
             поэтому combo не висит «белым островом» на тёмном/бежевом фоне.
             Минимальный кастомный template без зависимостей от системных
             цветов: ToggleButton + ContentPresenter + Popup. -->
        <Style x:Key="ThemedComboBoxToggle" TargetType="ToggleButton">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{DynamicResource WindowBackgroundBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="22" />
                                </Grid.ColumnDefinitions>
                                <ContentPresenter Grid.Column="0"
                                                  Margin="8,4,0,4"
                                                  HorizontalAlignment="Left"
                                                  VerticalAlignment="Center" />
                                <Path Grid.Column="1"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Data="M 0,0 L 8,0 L 4,5 Z"
                                      Fill="{DynamicResource SecondaryTextBrush}" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource SidebarBackgroundBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ThemedComboBoxItem" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="Background" Value="{DynamicResource WindowBackgroundBrush}" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource AccentBrush}" />
                                <Setter Property="Foreground"
                                        Value="{DynamicResource WindowBackgroundBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource SidebarBackgroundBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ThemedComboBox" TargetType="ComboBox">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="Background" Value="{DynamicResource WindowBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource ThemedComboBoxItem}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Style="{StaticResource ThemedComboBoxToggle}"
                                          IsChecked="{Binding IsDropDownOpen,
                                              Mode=TwoWay,
                                              RelativeSource={RelativeSource TemplatedParent}}">
                                <ContentPresenter x:Name="ContentSite"
                                                  IsHitTestVisible="False"
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                                  TextElement.Foreground="{DynamicResource TextBrush}" />
                            </ToggleButton>
                            <Popup x:Name="Popup"
                                   AllowsTransparency="True"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   PopupAnimation="Slide">
                                <Border Background="{DynamicResource WindowBackgroundBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        MinWidth="{TemplateBinding ActualWidth}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <ScrollViewer SnapsToDevicePixels="True"
                                                  VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Кнопка панели инструментов: тонкая рамка, hover заливает AccentBrush
             и сливает рамку с фоном. -->
        <Style x:Key="ToolbarButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,7" />
            <Setter Property="Margin" Value="0,0,4,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"
                                              TextElement.Foreground="{TemplateBinding Foreground}"
                                              TextElement.FontFamily="{TemplateBinding FontFamily}"
                                              TextElement.FontSize="{TemplateBinding FontSize}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentBrush}" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource WindowBackgroundBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Большая кнопка onboarding-экрана. -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource WindowBackgroundBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="22,10" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"
                                              TextElement.Foreground="{TemplateBinding Foreground}"
                                              TextElement.FontFamily="{TemplateBinding FontFamily}"
                                              TextElement.FontSize="{TemplateBinding FontSize}"
                                              TextElement.FontWeight="{TemplateBinding FontWeight}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.85" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="MenuItem">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="Background" Value="{DynamicResource WindowBackgroundBrush}" />
        </Style>

        <Style TargetType="Menu">
            <Setter Property="Background" Value="{DynamicResource WindowBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
        </Style>

        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>

        <Style x:Key="ProfileCardBorder" TargetType="Border">
            <Setter Property="BorderThickness" Value="1.5" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Style.Triggers>
                <!-- Hover на неактивной карточке — рамка подсвечивается
                     акцентным цветом, чтобы дать визуальную обратную связь. -->
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                </Trigger>
                <DataTrigger Binding="{Binding IsActive}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ProfileCardTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsActive}" Value="True">
                    <Setter Property="FontWeight" Value="Bold" />
                    <Setter Property="Foreground" Value="{DynamicResource WindowBackgroundBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ProfileCardHotkey" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Margin" Value="0,3,0,0" />
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsActive}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource WindowBackgroundBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SettingLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,0,0,5" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        </Style>

        <DataTemplate x:Key="ProfileCardTemplate" DataType="{x:Type vm:ProfileItemViewModel}">
            <Border Style="{StaticResource ProfileCardBorder}"
                    AllowDrop="True"
                    PreviewMouseLeftButtonDown="OnProfileCardPreviewMouseDown"
                    MouseMove="OnProfileCardMouseMove"
                    DragEnter="OnProfileCardDragEnter"
                    DragOver="OnProfileCardDragOver"
                    DragLeave="OnProfileCardDragLeave"
                    Drop="OnProfileCardDrop">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick"
                                  Command="{Binding ActivateCommand}" />
                </Border.InputBindings>
                <Border.ContextMenu>
                    <!-- ContextMenu в WPF — отдельный visual tree (Popup), поэтому
                         RelativeSource AncestorType=Window отсюда не работает.
                         Все команды живут на ProfileItemViewModel и для встроенных
                         профилей серые через CanExecute. -->
                    <ContextMenu>
                        <MenuItem Header="Активировать"
                                  Command="{Binding ActivateCommand}" />
                        <Separator />
                        <MenuItem Header="Переименовать..."
                                  Command="{Binding RenameCommand}" />
                        <MenuItem Header="Сохранить настройки в этот профиль"
                                  Command="{Binding OverwriteCommand}" />
                        <Separator />
                        <MenuItem Header="Удалить профиль"
                                  Command="{Binding DeleteCommand}" />
                    </ContextMenu>
                </Border.ContextMenu>
                <StackPanel>
                    <TextBlock Text="{Binding Name}" Style="{StaticResource ProfileCardTitle}" />
                    <TextBlock Text="{Binding HotkeyLabel}" Style="{StaticResource ProfileCardHotkey}" />
                </StackPanel>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid>
    <DockPanel>

        <!-- Главное меню -->
        <Menu DockPanel.Dock="Top"
              Visibility="{Binding IsNotReadingMode, Converter={StaticResource BoolToVis}}">
            <MenuItem Header="Файл">
                <MenuItem Header="Открыть..."
                          InputGestureText="Ctrl+O"
                          Command="{Binding OpenDocumentCommand}" />
                <MenuItem Header="Закрыть документ"
                          InputGestureText="Ctrl+W"
                          Command="{Binding CloseDocumentCommand}" />
                <MenuItem Header="Недавние"
                          ItemsSource="{Binding RecentFiles}"
                          IsEnabled="{Binding HasRecentFiles}">
                    <MenuItem.ItemContainerStyle>
                        <Style TargetType="MenuItem">
                            <Setter Property="Header" Value="{Binding}" />
                            <Setter Property="Command"
                                    Value="{Binding DataContext.OpenRecentCommand,
                                            RelativeSource={RelativeSource AncestorType=Window}}" />
                            <Setter Property="CommandParameter" Value="{Binding}" />
                        </Style>
                    </MenuItem.ItemContainerStyle>
                </MenuItem>
                <Separator />
                <MenuItem Header="Сохранить как профиль..."
                          InputGestureText="Ctrl+S"
                          Command="{Binding SaveProfileCommand}" />
                <Separator />
                <MenuItem Header="Выход" Command="{Binding ExitCommand}" />
            </MenuItem>
            <MenuItem Header="Профиль">
                <!-- Активные профили — встроенные с хоткеями + пользовательские
                     в том же списке. ItemsSource биндится к Profiles, поэтому
                     добавление/удаление/переименование сразу отражаются в меню. -->
                <MenuItem Header="Активировать" ItemsSource="{Binding Profiles}">
                    <MenuItem.ItemContainerStyle>
                        <Style TargetType="MenuItem">
                            <Setter Property="Header" Value="{Binding Name}" />
                            <Setter Property="Command" Value="{Binding ActivateCommand}" />
                            <Setter Property="InputGestureText" Value="{Binding Hotkey}" />
                        </Style>
                    </MenuItem.ItemContainerStyle>
                </MenuItem>
                <Separator />
                <MenuItem Header="Сохранить как новый профиль..."
                          InputGestureText="Ctrl+S"
                          Command="{Binding SaveProfileCommand}" />
                <MenuItem Header="Сохранить настройки в..."
                          ItemsSource="{Binding UserProfiles}"
                          IsEnabled="{Binding HasUserProfiles}">
                    <MenuItem.ItemContainerStyle>
                        <Style TargetType="MenuItem">
                            <Setter Property="Header" Value="{Binding Name}" />
                            <Setter Property="Command" Value="{Binding OverwriteCommand}" />
                        </Style>
                    </MenuItem.ItemContainerStyle>
                </MenuItem>
            </MenuItem>
            <MenuItem Header="Вид">
                <MenuItem Header="Увеличить шрифт"
                          InputGestureText="Ctrl++"
                          Command="{Binding IncreaseFontCommand}" />
                <MenuItem Header="Уменьшить шрифт"
                          InputGestureText="Ctrl+-"
                          Command="{Binding DecreaseFontCommand}" />
                <Separator />
                <MenuItem Header="Режим чтения"
                          InputGestureText="F11"
                          Command="{Binding ToggleReadingModeCommand}" />
            </MenuItem>
            <MenuItem Header="Озвучка">
                <MenuItem Header="{Binding PlayPauseLabel}"
                          InputGestureText="F5"
                          Command="{Binding PlayPauseCommand}" />
                <MenuItem Header="Остановить"
                          InputGestureText="Shift+F5"
                          Command="{Binding StopSpeechCommand}" />
            </MenuItem>
            <MenuItem Header="Справка">
                <MenuItem Header="Горячие клавиши..." Command="{Binding ShowHotkeysCommand}" />
                <Separator />
                <MenuItem Header="О программе" Command="{Binding ShowAboutCommand}" />
            </MenuItem>
        </Menu>

        <!-- Панель инструментов: только то, что реально работает. -->
        <Border DockPanel.Dock="Top"
                Visibility="{Binding IsNotReadingMode, Converter={StaticResource BoolToVis}}"
                Background="{DynamicResource WindowBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="12,10">
            <StackPanel Orientation="Horizontal">
                <Button Content="Открыть"
                        Command="{Binding OpenDocumentCommand}"
                        Style="{StaticResource ToolbarButton}" />
                <Button Content="Закрыть"
                        Command="{Binding CloseDocumentCommand}"
                        ToolTip="Закрыть документ (Ctrl+W)"
                        Style="{StaticResource ToolbarButton}" />
                <Button Content="Сохранить настройки"
                        Command="{Binding SaveProfileCommand}"
                        ToolTip="Сохранить текущие настройки как новый профиль (Ctrl+S)"
                        Style="{StaticResource ToolbarButton}" />

                <Rectangle Width="1" Margin="10,4"
                           Fill="{DynamicResource BorderBrush}" />

                <Button Content="A−"
                        Command="{Binding DecreaseFontCommand}"
                        FontWeight="SemiBold"
                        Style="{StaticResource ToolbarButton}" />
                <TextBlock Text="{Binding CurrentFontSize, StringFormat={}{0:0}pt}"
                           VerticalAlignment="Center"
                           Margin="6,0"
                           MinWidth="36"
                           TextAlignment="Center"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           FontSize="12" />
                <Button Content="A+"
                        Command="{Binding IncreaseFontCommand}"
                        FontWeight="SemiBold"
                        Style="{StaticResource ToolbarButton}" />

                <Rectangle Width="1" Margin="10,4"
                           Fill="{DynamicResource BorderBrush}" />

                <Button Content="{Binding PlayPauseLabel}"
                        Command="{Binding PlayPauseCommand}"
                        ToolTip="Озвучить текст (F5)"
                        Style="{StaticResource ToolbarButton}" />
                <Button Content="Стоп"
                        Command="{Binding StopSpeechCommand}"
                        ToolTip="Остановить озвучку (Shift+F5)"
                        Style="{StaticResource ToolbarButton}" />
            </StackPanel>
        </Border>

        <!-- Строка состояния -->
        <Border DockPanel.Dock="Bottom"
                Visibility="{Binding IsNotReadingMode, Converter={StaticResource BoolToVis}}"
                Background="{DynamicResource SidebarBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="12,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{Binding DocumentInfo}"
                           FontSize="12"
                           Foreground="{DynamicResource SecondaryTextBrush}" />
                <TextBlock Grid.Column="1"
                           Text="{Binding StatusText}"
                           FontSize="12"
                           Foreground="{DynamicResource SecondaryTextBrush}" />
            </Grid>
        </Border>

        <Grid>
            <Grid.ColumnDefinitions>
                <!-- В режиме чтения колонка sidebar схлопывается до нуля,
                     иначе при Visibility=Collapsed на самом Border пустые
                     240 px остаются. -->
                <ColumnDefinition>
                    <ColumnDefinition.Style>
                        <Style TargetType="ColumnDefinition">
                            <Setter Property="Width" Value="240" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsReadingMode}" Value="True">
                                    <Setter Property="Width" Value="0" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ColumnDefinition.Style>
                </ColumnDefinition>
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Visibility="{Binding IsNotReadingMode, Converter={StaticResource BoolToVis}}"
                    Background="{DynamicResource SidebarBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,1,0">
                <!-- ScrollViewer вокруг всего sidebar — иначе при большом
                     количестве пользовательских профилей список не помещается
                     по высоте и без прокрутки до настроек не добраться. -->
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="16,18">
                    <StackPanel>
                        <TextBlock Text="ПРОФИЛИ" Style="{StaticResource SectionLabel}" />

                        <ItemsControl ItemsSource="{Binding Profiles}"
                                      ItemTemplate="{StaticResource ProfileCardTemplate}" />

                        <Rectangle Height="1" Margin="0,18,0,18"
                                   Fill="{DynamicResource BorderBrush}" />

                        <TextBlock Text="НАСТРОЙКИ" Style="{StaticResource SectionLabel}" />

                        <TextBlock Text="Шрифт" Style="{StaticResource SettingLabel}" />
                        <ComboBox ItemsSource="{Binding AvailableFonts}"
                                  SelectedItem="{Binding CurrentFontFamily}"
                                  Margin="0,0,0,14"
                                  Style="{StaticResource ThemedComboBox}" />

                        <TextBlock Text="Межстрочный интервал" Style="{StaticResource SettingLabel}" />
                        <Slider Minimum="1" Maximum="3"
                                Value="{Binding CurrentLineHeight, Mode=TwoWay}"
                                TickFrequency="0.5"
                                IsSnapToTickEnabled="False" />
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Область чтения. Два состояния: onboarding (нет документа) и
                 текстовый просмотр (документ открыт). Visibility — через
                 BooleanToVisibilityConverter и инверсный bool в VM. -->
            <Grid Grid.Column="1" Background="{DynamicResource ReadingBackgroundBrush}">

                <!-- Onboarding-экран до первого открытия документа. -->
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            MaxWidth="460"
                            Visibility="{Binding HasNoDocument, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="ЯсноТекст"
                               FontSize="40"
                               FontWeight="SemiBold"
                               TextAlignment="Center"
                               Foreground="{DynamicResource TextBrush}" />
                    <TextBlock Text="Превращает «недоступные» PDF, DOCX и сканы в удобную среду для чтения."
                               FontSize="14"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               LineHeight="22"
                               Margin="0,12,0,28"
                               Foreground="{DynamicResource SecondaryTextBrush}" />
                    <Button Content="Открыть документ"
                            Command="{Binding OpenDocumentCommand}"
                            Style="{StaticResource PrimaryButton}"
                            HorizontalAlignment="Center" />
                    <TextBlock Text="или нажмите Ctrl+O"
                               FontSize="11"
                               TextAlignment="Center"
                               Margin="0,10,0,28"
                               Foreground="{DynamicResource SecondaryTextBrush}" />
                    <TextBlock TextAlignment="Center"
                               LineHeight="22"
                               FontSize="12"
                               Foreground="{DynamicResource SecondaryTextBrush}">
                        <Run Text="Профиль чтения: " />
                        <Run Text="Ctrl+1" FontWeight="SemiBold" />
                        <Run Text=" · " />
                        <Run Text="Ctrl+2" FontWeight="SemiBold" />
                        <Run Text=" · " />
                        <Run Text="Ctrl+3" FontWeight="SemiBold" />
                        <LineBreak />
                        <Run Text="Размер шрифта: " />
                        <Run Text="Ctrl++" FontWeight="SemiBold" />
                        <Run Text=" / " />
                        <Run Text="Ctrl+−" FontWeight="SemiBold" />
                    </TextBlock>
                </StackPanel>

                <!-- Текст документа. FlowDocumentScrollViewer вместо TextBlock —
                     у первого встроенная виртуализация на уровне Paragraph,
                     один TextBlock на 250-страничный PDF просто не скроллится.
                     Бонусом возвращается выделение/копирование текста и
                     встроенный поиск Ctrl+F. FlowDocument строится в
                     code-behind: см. UpdateReadingDocument в MainWindow.xaml.cs. -->
                <FlowDocumentScrollViewer x:Name="ReadingViewer"
                                          IsToolBarVisible="False"
                                          Background="{DynamicResource ReadingBackgroundBrush}"
                                          Foreground="{DynamicResource TextBrush}"
                                          FontFamily="{Binding CurrentFontFamily}"
                                          FontSize="{Binding CurrentFontSize}"
                                          Visibility="{Binding HasDocument, Converter={StaticResource BoolToVis}}" />

                <!-- Overlay для индикатора автопрокрутки. IsHitTestVisible=False,
                     чтобы клики через якорь доходили до viewer'а. Видимость и
                     позиция управляются из code-behind. -->
                <Canvas x:Name="AutoScrollOverlay"
                        IsHitTestVisible="False"
                        Visibility="Collapsed">
                    <Border x:Name="AutoScrollAnchor"
                            Width="36" Height="36"
                            CornerRadius="18"
                            Background="#A0606060"
                            BorderBrush="#FFFFFFFF"
                            BorderThickness="1">
                        <TextBlock Text="↕"
                                   Foreground="White"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>
                </Canvas>
            </Grid>
        </Grid>

    </DockPanel>

        <!-- Подсказка-кнопка выхода из режима чтения. Через 3 секунды плавно
             исчезает, чтобы не мешала чтению. Возвращается через
             OnWindowPreviewMouseMoveForReadingHint handler в code-behind.
             Клик по плашке = ToggleReadingModeCommand (т.е. выход). -->
        <Button x:Name="ReadingModeHint"
                Visibility="{Binding IsReadingMode, Converter={StaticResource BoolToVis}}"
                Command="{Binding ToggleReadingModeCommand}"
                HorizontalAlignment="Right" VerticalAlignment="Top"
                Margin="16"
                ToolTip="Выйти из режима чтения (F11 / Esc)"
                Cursor="Hand"
                Focusable="False">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Padding="12,6"
                            CornerRadius="4"
                            Background="#A0606060">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="✕"
                                       Foreground="White"
                                       FontSize="12"
                                       FontWeight="Bold"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="Выйти из режима чтения"
                                       Foreground="White"
                                       FontSize="11"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#D0303030" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>

        <!-- Overlay при drag-and-drop файла. IsHitTestVisible=False, чтобы
             события Drop/DragLeave доходили до Window — иначе drop попадал бы
             в overlay и не срабатывал. Полупрозрачный чёрный фон одинаково
             хорошо смотрится на всех трёх темах. -->
        <Border x:Name="DropOverlay"
                Visibility="Collapsed"
                IsHitTestVisible="False"
                Background="#B0000000">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                <TextBlock Text="Отпустите, чтобы открыть"
                           FontSize="28"
                           FontWeight="SemiBold"
                           Foreground="White"
                           HorizontalAlignment="Center" />
                <TextBlock Text="PDF · DOCX · изображение"
                           FontSize="13"
                           Foreground="#CCFFFFFF"
                           Margin="0,10,0,0"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
