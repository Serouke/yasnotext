<Window x:Class="YasnoText.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:YasnoText.UI.ViewModels"
        mc:Ignorable="d"
        Title="ЯсноТекст"
        Height="700"
        Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource TextBrush}"
        FontFamily="{DynamicResource UIFontFamily}">

    <Window.Resources>

        <Style x:Key="ToolbarButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource WindowBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="Margin" Value="2" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"
                                              TextElement.Foreground="{TemplateBinding Foreground}"
                                              TextElement.FontFamily="{TemplateBinding FontFamily}"
                                              TextElement.FontSize="{TemplateBinding FontSize}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource WindowBackgroundBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="MenuItem">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="Background" Value="{DynamicResource WindowBackgroundBrush}" />
        </Style>

        <Style TargetType="Menu">
            <Setter Property="Background" Value="{DynamicResource WindowBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
        </Style>

        <Style x:Key="ProfileCardBorder" TargetType="Border">
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsActive}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ProfileCardTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsActive}" Value="True">
                    <Setter Property="FontWeight" Value="Bold" />
                    <Setter Property="Foreground" Value="{DynamicResource WindowBackgroundBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ProfileCardHotkey" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Margin" Value="0,2,0,0" />
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsActive}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource WindowBackgroundBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <DataTemplate x:Key="ProfileCardTemplate" DataType="{x:Type vm:ProfileItemViewModel}">
            <Border Style="{StaticResource ProfileCardBorder}">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick"
                                  Command="{Binding DataContext.SelectProfileCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                  CommandParameter="{Binding}" />
                </Border.InputBindings>
                <StackPanel>
                    <TextBlock Text="{Binding Name}" Style="{StaticResource ProfileCardTitle}" />
                    <TextBlock Text="{Binding HotkeyLabel}" Style="{StaticResource ProfileCardHotkey}" />
                </StackPanel>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <DockPanel>

        <!-- Главное меню -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="Файл">
                <MenuItem Header="Открыть..."
                          InputGestureText="Ctrl+O"
                          Command="{Binding OpenDocumentCommand}" />
                <MenuItem Header="Сохранить как профиль..."
                          InputGestureText="Ctrl+S"
                          Command="{Binding SaveProfileCommand}" />
                <Separator />
                <MenuItem Header="Выход" />
            </MenuItem>
            <MenuItem Header="Профиль">
                <MenuItem Header="Стандартный"
                          InputGestureText="Ctrl+1"
                          Command="{Binding SelectProfileCommand}"
                          CommandParameter="{Binding Profiles[0]}" />
                <MenuItem Header="Слабовидение"
                          InputGestureText="Ctrl+2"
                          Command="{Binding SelectProfileCommand}"
                          CommandParameter="{Binding Profiles[1]}" />
                <MenuItem Header="Дислексия"
                          InputGestureText="Ctrl+3"
                          Command="{Binding SelectProfileCommand}"
                          CommandParameter="{Binding Profiles[2]}" />
            </MenuItem>
            <MenuItem Header="Вид">
                <MenuItem Header="Увеличить шрифт"
                          InputGestureText="Ctrl++"
                          Command="{Binding IncreaseFontCommand}" />
                <MenuItem Header="Уменьшить шрифт"
                          InputGestureText="Ctrl+-"
                          Command="{Binding DecreaseFontCommand}" />
            </MenuItem>
            <MenuItem Header="Озвучка">
                <MenuItem Header="Прочитать вслух" />
                <MenuItem Header="Остановить" />
            </MenuItem>
            <MenuItem Header="Справка">
                <MenuItem Header="О программе" />
            </MenuItem>
        </Menu>

        <!-- Панель инструментов -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource WindowBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="10,8">
            <StackPanel Orientation="Horizontal">
                <Button Content="📂 Открыть"
                        Command="{Binding OpenDocumentCommand}"
                        Style="{StaticResource ToolbarButton}" />
                <Button Content="💾 Сохранить"
                        Command="{Binding SaveProfileCommand}"
                        ToolTip="Сохранить текущие настройки как новый профиль"
                        Style="{StaticResource ToolbarButton}" />
                <Rectangle Width="1" Margin="6,2"
                           Fill="{DynamicResource BorderBrush}" />
                <Button Content="🔍 Распознать (OCR)" Style="{StaticResource ToolbarButton}" />
                <Rectangle Width="1" Margin="6,2"
                           Fill="{DynamicResource BorderBrush}" />
                <Button Content="A−"
                        Command="{Binding DecreaseFontCommand}"
                        Style="{StaticResource ToolbarButton}" />
                <TextBlock Text="{Binding CurrentFontSize, StringFormat={}{0:0}pt}"
                           VerticalAlignment="Center"
                           Margin="8,0"
                           MinWidth="40"
                           TextAlignment="Center"
                           Foreground="{DynamicResource TextBrush}" />
                <Button Content="A+"
                        Command="{Binding IncreaseFontCommand}"
                        Style="{StaticResource ToolbarButton}" />
                <Rectangle Width="1" Margin="6,2"
                           Fill="{DynamicResource BorderBrush}" />
                <Button Content="▶ Озвучить" Style="{StaticResource ToolbarButton}" />
            </StackPanel>
        </Border>

        <!-- Строка состояния -->
        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource SidebarBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="10,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{Binding DocumentInfo}"
                           Foreground="{DynamicResource SecondaryTextBrush}" />
                <TextBlock Grid.Column="1"
                           Text="{Binding StatusText}"
                           Foreground="{DynamicResource SecondaryTextBrush}" />
            </Grid>
        </Border>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{DynamicResource SidebarBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,1,0"
                    Padding="12">
                <StackPanel>
                    <TextBlock Text="ПРОФИЛИ"
                               FontSize="11"
                               FontWeight="Medium"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               Margin="0,0,0,8" />

                    <ItemsControl ItemsSource="{Binding Profiles}"
                                  ItemTemplate="{StaticResource ProfileCardTemplate}" />

                    <TextBlock Text="НАСТРОЙКИ"
                               FontSize="11"
                               FontWeight="Medium"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               Margin="0,16,0,8" />

                    <TextBlock Text="Шрифт"
                               FontSize="12"
                               Margin="0,0,0,4"
                               Foreground="{DynamicResource TextBrush}" />
                    <ComboBox ItemsSource="{Binding AvailableFonts}"
                              SelectedItem="{Binding CurrentFontFamily}"
                              Margin="0,0,0,10"
                              Foreground="Black" />

                    <TextBlock Text="Межбуквенный интервал"
                               FontSize="12"
                               Margin="0,0,0,4"
                               Foreground="{DynamicResource TextBrush}" />
                    <Slider Minimum="0" Maximum="6"
                            Value="{Binding CurrentLetterSpacing, Mode=TwoWay}"
                            Margin="0,0,0,10" />

                    <TextBlock Text="Высота строки"
                               FontSize="12"
                               Margin="0,0,0,4"
                               Foreground="{DynamicResource TextBrush}" />
                    <Slider Minimum="1" Maximum="3"
                            Value="{Binding CurrentLineHeight, Mode=TwoWay}"
                            TickFrequency="0.5" />
                </StackPanel>
            </Border>

            <!-- Область чтения. TextBlock вместо TextBox — у TextBox нет
                 LineHeight, который критичен для профиля «Дислексия». Выделение
                 текста при этом теряется (в WPF TextBlock его не поддерживает),
                 для read-only приложения это приемлемый компромисс MVP. -->
            <ScrollViewer Grid.Column="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Background="{DynamicResource ReadingBackgroundBrush}">
                <TextBlock Text="{Binding DocumentText, Mode=OneWay}"
                           Background="{DynamicResource ReadingBackgroundBrush}"
                           Foreground="{DynamicResource TextBrush}"
                           FontFamily="{Binding CurrentFontFamily}"
                           FontSize="{Binding CurrentFontSize}"
                           LineHeight="{Binding EffectiveLineHeight}"
                           Padding="32,24"
                           TextWrapping="Wrap" />
            </ScrollViewer>
        </Grid>

    </DockPanel>
</Window>
